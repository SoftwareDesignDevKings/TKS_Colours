# Environment Configuration
# Copy this file to .env and fill in your values

# Database
# Local development:
DATABASE_URL=postgresql+asyncpg://tks_admin:changeme@localhost:5432/tks_colours
# Supabase (for production — use your Supabase project's connection string):
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Email (for reminder notifications)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@school.edu
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=TKS Colours
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# App
APP_ENV=development
SECRET_KEY=change-this-in-production

# Vercel Cron (optional — secures the /api/v1/cron/* endpoints)
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=

